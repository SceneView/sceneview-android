# Example .dev.vars file for `wrangler dev`. Copy to .dev.vars and
# fill in the values below — NEVER commit .dev.vars.
#
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET = "replace-with-at-least-32-random-bytes-hex"

# Resend API key — leave empty in local dev to skip email sending.
# The /login POST still succeeds and the magic link row is written.
RESEND_API_KEY = ""

# Stripe test keys — required to exercise /billing/checkout locally.
STRIPE_SECRET_KEY = "sk_test_REPLACE_ME"
STRIPE_WEBHOOK_SECRET = "whsec_test_REPLACE_ME"

# Stripe test price ids (create the products in your Stripe test mode).
STRIPE_PRICE_PRO_MONTHLY = "price_test_pro_monthly"
STRIPE_PRICE_PRO_YEARLY = "price_test_pro_yearly"
STRIPE_PRICE_TEAM_MONTHLY = "price_test_team_monthly"
STRIPE_PRICE_TEAM_YEARLY = "price_test_team_yearly"
