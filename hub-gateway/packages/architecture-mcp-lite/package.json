{
  "name": "architecture-mcp",
  "version": "2.0.0-beta.1",
  "description": "Lite npm wrapper that forwards architecture-mcp tool calls to the hub-mcp hosted gateway. Previously shipped full tool logic; this line of 2.x moves to a proxy architecture so one subscription covers the whole non-SceneView MCP portfolio.",
  "type": "module",
  "bin": {
    "architecture-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "dev": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "architecture",
    "3d",
    "bim",
    "floor-plan",
    "sceneview"
  ],
  "author": "Thomas Gorisse <thomas.gorisse@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sceneview-tools/architecture-mcp.git"
  },
  "homepage": "https://hub-mcp.mcp-tools-lab.workers.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18"
  }
}
