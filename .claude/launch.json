{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sceneview-website",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "../sceneview.github.io"],
      "port": 8080
    },
    {
      "name": "website-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "9090", "--directory", "website-static"],
      "port": 9090
    },
    {
      "name": "mkdocs",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "mkdocs", "serve", "--dev-addr", "127.0.0.1:8000"],
      "port": 8000
    },
    {
      "name": "mcp-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "mcp"],
      "port": 3000
    },
    {
      "name": "hub-gateway",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "wrangler",
        "dev",
        "--config",
        "hub-gateway/wrangler.toml",
        "--port",
        "8787",
        "--local",
        "--ip",
        "127.0.0.1"
      ],
      "port": 8787
    }
  ]
}
