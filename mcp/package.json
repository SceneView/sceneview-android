{
  "name": "sceneview-mcp",
  "version": "3.4.10",
  "mcpName": "io.github.sceneview/mcp",
  "description": "MCP server for SceneView — cross-platform 3D & AR SDK for Android and iOS. Give Claude the full SceneView SDK so it writes correct, compilable code.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sceneview",
    "android",
    "ios",
    "ar",
    "arcore",
    "arkit",
    "3d",
    "filament",
    "realitykit",
    "jetpack-compose",
    "swiftui",
    "kotlin-multiplatform",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "author": "SceneView (https://github.com/sceneview)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview/sceneview.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/sceneview/sceneview/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/sceneview/sceneview/issues"
  },
  "type": "module",
  "bin": {
    "sceneview-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/issues.js",
    "dist/guides.js",
    "dist/migration.js",
    "dist/node-reference.js",
    "dist/samples.js",
    "dist/preview.js",
    "dist/artifact.js",
    "dist/validator.js",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "cp ../llms.txt ./llms.txt && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
