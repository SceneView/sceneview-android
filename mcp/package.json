{
  "name": "sceneview-mcp",
  "version": "4.0.0",
  "mcpName": "io.github.sceneview/mcp",
  "description": "MCP server for SceneView — cross-platform 3D & AR SDK for Android and iOS. Give Claude the full SceneView SDK so it writes correct, compilable code.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sceneview",
    "android",
    "ios",
    "ar",
    "arcore",
    "arkit",
    "3d",
    "filament",
    "realitykit",
    "jetpack-compose",
    "swiftui",
    "kotlin-multiplatform",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "author": "SceneView (https://github.com/sceneview)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview/sceneview.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/sceneview/sceneview/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/sceneview/sceneview/issues"
  },
  "type": "module",
  "bin": {
    "sceneview-mcp": "dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "!dist/**/__fixtures__/**",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "prebuild": "node scripts/generate-llms-txt.js",
    "build": "tsc",
    "prepare": "cp ../llms.txt ./llms.txt && node scripts/generate-llms-txt.js && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node scripts/generate-llms-txt.js && vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/sceneview"
    },
    {
      "type": "individual",
      "url": "https://github.com/sponsors/sceneview"
    }
  ]
}
