{
  "name": "sceneview-mcp",
  "version": "3.6.1",
  "mcpName": "io.github.sceneview/mcp",
  "description": "MCP server for SceneView — cross-platform 3D & AR SDK for Android and iOS. Give Claude the full SceneView SDK so it writes correct, compilable code.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sceneview",
    "android",
    "ios",
    "ar",
    "arcore",
    "arkit",
    "3d",
    "filament",
    "realitykit",
    "jetpack-compose",
    "swiftui",
    "kotlin-multiplatform",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "author": "SceneView (https://github.com/sceneview)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview/sceneview.git",
    "directory": "mcp"
  },
  "homepage": "https://github.com/sceneview/sceneview/tree/main/mcp#readme",
  "bugs": {
    "url": "https://github.com/sceneview/sceneview/issues"
  },
  "type": "module",
  "bin": {
    "sceneview-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/issues.js",
    "dist/guides.js",
    "dist/migration.js",
    "dist/node-reference.js",
    "dist/samples.js",
    "dist/preview.js",
    "dist/artifact.js",
    "dist/validator.js",
    "dist/platform-setup.js",
    "dist/migrate-code.js",
    "dist/debug-issue.js",
    "dist/generate-scene.js",
    "dist/advanced-guides.js",
    "dist/extra-guides.js",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "cp ../llms.txt ./llms.txt && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/sceneview"
    },
    {
      "type": "polar",
      "url": "https://polar.sh/sceneview"
    }
  ]
}
