{
  "name": "sceneview-mcp",
  "version": "3.2.0",
  "description": "MCP server for SceneView — 3D and AR with Jetpack Compose for Android. Give Claude the full SceneView SDK so it writes correct, compilable Kotlin.",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sceneview",
    "android",
    "ar",
    "arcore",
    "3d",
    "3d-rendering",
    "filament",
    "google-filament",
    "jetpack-compose",
    "compose",
    "kotlin",
    "augmented-reality",
    "mixed-reality",
    "glb",
    "gltf",
    "pbr",
    "scene-graph",
    "ai",
    "ai-tools",
    "claude",
    "cursor",
    "windsurf",
    "llm",
    "code-generation",
    "android-development",
    "mobile-ar"
  ],
  "license": "Apache-2.0",
  "author": "SceneView (https://github.com/SceneView)",
  "repository": {
    "type": "git",
    "url": "https://github.com/SceneView/sceneview.git",
    "directory": "mcp"
  },
  "homepage": "https://sceneview.github.io/ai-development/",
  "bugs": {
    "url": "https://github.com/SceneView/sceneview/issues"
  },
  "type": "module",
  "bin": {
    "sceneview-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/issues.js",
    "dist/migration.js",
    "dist/node-reference.js",
    "dist/samples.js",
    "dist/validator.js",
    "dist/guides.js",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "cp ../llms.txt ./llms.txt && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  }
}
