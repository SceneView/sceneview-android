{
  "name": "automotive-3d-mcp",
  "version": "1.0.0",
  "description": "MCP server for Automotive 3D visualization with SceneView — car configurators, HUD overlays, 3D dashboards, AR showrooms, and parts catalogs.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sceneview",
    "automotive",
    "car",
    "3d",
    "configurator",
    "hud",
    "dashboard",
    "ar-showroom",
    "parts-catalog",
    "android",
    "jetpack-compose",
    "kotlin",
    "claude",
    "ai"
  ],
  "license": "Apache-2.0",
  "author": "SceneView (https://github.com/sceneview)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview/sceneview.git",
    "directory": "mcp-automotive"
  },
  "homepage": "https://github.com/sceneview/sceneview/tree/main/mcp-automotive#readme",
  "bugs": {
    "url": "https://github.com/sceneview/sceneview/issues"
  },
  "type": "module",
  "bin": {
    "automotive-3d-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "dist/car-configurator.js",
    "dist/hud-overlay.js",
    "dist/dashboard-3d.js",
    "dist/ar-showroom.js",
    "dist/parts-catalog.js",
    "dist/car-models.js",
    "dist/validator.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "picomatch": ">=4.0.4"
  }
}
