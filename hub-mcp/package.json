  "bin": {
    "hub-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "ai",
    "tools",
    "architecture",
    "real-estate",
    "finance",
    "education",
    "legal",
    "healthcare",
    "automotive",
    "ecommerce",
    "social-media",
    "health-fitness",
    "french-admin"
  ],
  "author": "Thomas Gorisse",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tools-lab/hub-mcp"
  },
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
