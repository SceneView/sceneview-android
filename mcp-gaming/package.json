  },
  "files": [
    "dist/index.js",
    "dist/character-viewer.js",
    "dist/level-editor.js",
    "dist/physics-game.js",
    "dist/particle-effects.js",
    "dist/inventory-3d.js",
    "dist/game-models.js",
    "dist/validator.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
