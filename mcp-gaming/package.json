    "character-viewer",
    "level-editor",
    "physics",
    "particles",
    "inventory",
    "android",
    "jetpack-compose",
    "kotlin",
    "claude",
    "ai"
  ],
  "license": "Apache-2.0",
  "author": "SceneView (https://github.com/sceneview)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sceneview/sceneview.git",
    "directory": "mcp-gaming"
  },
  "homepage": "https://github.com/sceneview/sceneview/tree/main/mcp-gaming#readme",
  "bugs": {
    "url": "https://github.com/sceneview/sceneview/issues"
  },
  "type": "module",
  "main": "dist/index.js",
